{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": false,
    "tsBuildInfoFile": null
  },
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "examples",
    "cypress",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.bench.ts",
    "src/dev/**/*"
  ]
}